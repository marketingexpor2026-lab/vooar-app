# Porta do servidor (Railway/Render definem automaticamente)
PORT=3000

# Diretório persistente para banco de dados e uploads
# No Railway: configure um Volume e coloque o mount path aqui
# Ex: /app/storage
STORAGE_DIR=/app/storage

# Token secreto do painel admin (troque por algo seguro em produção)
ADMIN_TOKEN=jvooardev25
